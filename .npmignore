# .npmignore — files excluded from the published npm package

# Source (TypeScript is compiled to dist/)
src/
scripts/*.py

# Test infrastructure
**/*.spec.ts
**/*.test.ts
jest.config.cjs

# TypeScript config (not needed at runtime)
tsconfig.json

# Dev tooling
.eslintrc*
.prettierrc*

# Local data directories
.mcp-dev/
coverage/

# Git
.git/
.gitignore
