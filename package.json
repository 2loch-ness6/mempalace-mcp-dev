{
  "name": "@mempalace/mcp-dev",
  "version": "1.0.0",
  "description": "MCP server for branch-scoped code grounding, change ledger, semantic search via MemPalace, and project-track management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mempalace-mcp-dev": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --config jest.config.cjs",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --config jest.config.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "devtools",
    "mempalace",
    "semantic-search",
    "conductor",
    "project-tracking",
    "code-search"
  ],
  "author": "MemPalace Contributors",
  "license": "MIT",
  "files": [
    "dist",
    "scripts",
    "templates",
    "README.md",
    "LICENSE",
    "mempalace.yaml.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "graceful-fs": "^4.2.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
